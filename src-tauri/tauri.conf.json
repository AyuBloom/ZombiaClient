{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MilkTea",
  "version": "0.8.3",
  "identifier": "com.milktea-zombia-client.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MilkTea 🧋",
        "width": 1080,
        "height": 768,
        "minWidth": 720,
        "minHeight": 720,
        "zoomHotkeysEnabled": true,
        "additionalBrowserArgs": "--enable-unsafe-webgpu"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "macos-fps": {
      "enabled": true
    },
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1RUQ1NTU5MThGNzY4RUUKUldUdWFQY1lXVlh0TmMvdnk4M2NpY28zVXNJQ1ltQ3dBSktzK3VPajVYZFJNbHpGYXdMNkEzVlYK",
      "endpoints": [
        "https://raw.githubusercontent.com/AyuBloom/MilkTea/updater/updater.json"
      ]
    },
    "dialog": {
      "enabled": true
    }
  }
}
